# Copy to .env.local and fill in values. Do not commit .env.local.

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_ACCOUNT=acct_xxx
# Optional: base URL for Stripe return redirect (e.g. http://localhost:3000). Falls back to request origin if unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
